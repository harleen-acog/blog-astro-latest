---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const usernames = [...new Set(allPosts.map((e) => e.id.split('/')[0]))];

  return usernames.map((username) => ({
    params: { username },
  }));
}

const { username } = Astro.params;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const posts = allPosts
  .filter((e) => e.id.split('/')[0] === username)
  .map((e) => ({
    slug: e.id.split('/')[1],
    title: e.data.title,
    description: e.data.description,
    date: e.data.date,
    tags: e.data.tags,
  }))
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());

const user = { name: username, username };
---

<Layout title={`${user.name} | Blog`} description={`Posts by ${user.name}`}>
  <Header user={user} slot="Header"/>

  <section class="blog-page">

    <header class="blog-header">
      <div class="header-top">
        <div class="header-left">
          <p class="header-eyebrow">Writing</p>
          <h1>{user.name}'s Blog</h1>
        </div>
        <span class="post-count" id="result-count">
          {posts.length} post{posts.length !== 1 ? 's' : ''}
        </span>
      </div>

      <div class="search-wrap">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search"
          type="text"
          placeholder="Search posts..."
          class="search-input"
          autocomplete="off"
        />
      </div>
    </header>

    {posts.length === 0 ? (
      <div class="empty">
        <p>No posts yet.</p>
      </div>
    ) : (
      <>
        <div class="posts-list" id="posts">
          {posts.map((post) => (
            <a
              href={`/${username}/blog/${post.slug}`}
              class="post-card"
              data-title={post.title.toLowerCase()}
              data-excerpt={(post.description || '').toLowerCase()}
            >
              <div class="post-main">
                <div class="post-meta">
                  <time class="post-date">
                    {new Date(post.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  {post.tags && post.tags.length > 0 && (
                    <div class="tags">
                      {post.tags.slice(0, 3).map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>

                <h3>{post.title}</h3>

                {post.description && (
                  <p class="post-excerpt">{post.description}</p>
                )}
              </div>

              <span class="post-arrow">→</span>
            </a>
          ))}
        </div>

        <p class="empty-search" id="empty-state" style="display:none;">
          No posts match your search.
        </p>
      </>
    )}

  </section>
</Layout>

<script>
  const searchInput = document.getElementById("search") as HTMLInputElement;
  const posts = document.querySelectorAll<HTMLElement>(".post-card");
  const emptyState = document.getElementById("empty-state");
  const resultCount = document.getElementById("result-count");

  searchInput?.addEventListener("input", (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
    let visibleCount = 0;

    posts.forEach((post) => {
      const title = post.dataset.title || "";
      const excerpt = post.dataset.excerpt || "";
      const match = title.includes(query) || excerpt.includes(query);
      post.style.display = match ? "flex" : "none";
      if (match) visibleCount++;
    });

    if (resultCount) {
      resultCount.textContent = `${visibleCount} post${visibleCount !== 1 ? "s" : ""}`;
    }

    if (emptyState) {
      emptyState.style.display = visibleCount === 0 ? "block" : "none";
    }
  });
</script>

<style>
  .blog-page {
    max-width: 780px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
  }

  /* ── Header ── */
  .blog-header {
    margin-bottom: 2.5rem;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }

  .header-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.4rem 0;
  }

  .blog-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-text-main);
  }

  .post-count {
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    background: var(--color-bg-offset);
    white-space: nowrap;
  }

  /* ── Search ── */
  .search-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.5rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-offset);
    color: var(--color-text-main);
    font-size: 0.9rem;
    box-sizing: border-box;
    transition: border-color 0.2s ease;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  /* ── Posts list ── */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Card ── */
  .post-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem 1rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: padding-left 0.2s ease;
    border-left: 3px solid transparent;
  }

  .post-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-card:hover {
    padding-left: 1.4rem;
    border-left-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  .post-main {
    flex: 1;
    min-width: 0;
  }

  /* ── Meta row ── */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    text-transform: uppercase;
  }

  /* ── Title ── */
  .post-card h3 {
    margin: 0 0 0.35rem 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.3;
  }

  /* ── Excerpt ── */
  .post-excerpt {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Arrow ── */
  .post-arrow {
    flex-shrink: 0;
    font-size: 1rem;
    color: var(--color-text-muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .post-card:hover .post-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

  /* ── Empty states ── */
  .empty,
  .empty-search {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding: 3rem 0;
    text-align: center;
  }
</style>