---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogPreview from '../../components/BlogPreview.astro';

import UserLayout from "../../../layouts/UserLayout.astro";
import Hero from "../../../components/user/Hero.astro";
import "../../../styles/global.css"

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const usernames = [...new Set(allPosts.map((e) => e.id.split('/')[0]))];

  return usernames.map((username) => ({
    params: { username },
  }));
}

const { username } = Astro.params;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allAuthors = await getCollection('authors');

const profile = allAuthors.find((a) => a.id === username);

const user = {
  username,
  name: profile?.data.name ?? username,
  avatar: profile?.data.avatar_url ?? `https://avatars.githubusercontent.com/${username}`,
  bio: profile?.data.bio ?? null,
};


const posts = allPosts
  .filter((e) => e.id.split('/')[0] === username)
  .map((e) => ({
    slug: e.id.split('/')[1],
    title: e.data.title,
    description: e.data.description,
    date: e.data.date,
    tags: e.data.tags,
  }))
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<UserLayout user={user}>

  <Hero user={user} />

  <div class="grid-2" style="gap: 4rem;">
    <BlogPreview posts={posts} username={username} />
  </div>
</UserLayout>