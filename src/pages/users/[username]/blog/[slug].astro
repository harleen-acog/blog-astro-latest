---
import { getUsers, getUserByUsername } from "../../../../lib/queries/users";
import { getPostsByUser, getPostBySlugAndUser } from "../../../../lib/queries/posts";
import { marked } from "marked";
import BlogPost from "../../../../layouts/BlogPost.astro";

export async function getStaticPaths() {
  const users = getUsers();

  const paths = [];

  for (const user of users) {
    const posts = getPostsByUser(user.id);

    for (const post of posts) {
      paths.push({
        params: {
          username: user.username,
          slug: post.slug,
        },
      });
    }
  }

  return paths;
}

const { username, slug } = Astro.params;

const user = getUserByUsername(username);
if (!user) throw new Error("User not found");

const post = getPostBySlugAndUser(slug, username);
if (!post) throw new Error("Post not found");

const html = marked(post.content);
---

<BlogPost post={post} user={user} html={html} />