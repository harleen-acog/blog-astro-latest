---
// src/pages/authors/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MainHeader from '../../components/MainHeader.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allAuthors = await getCollection('authors');

const usernames = [...new Set(allPosts.map((e) => e.id.split('/')[0]))];

const authors = usernames.map((username) => {
  const profile = allAuthors.find((a) => a.id === username);
  const postCount = allPosts.filter((e) => e.id.split('/')[0] === username).length;
  const latestPost = allPosts
    .filter((e) => e.id.split('/')[0] === username)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

  return {
    username,
    name: profile?.data.name ?? username,
    avatar: profile?.data.avatar_url ?? `https://avatars.githubusercontent.com/${username}`,
    bio: profile?.data.bio ?? null,
    postCount,
    latestPost: latestPost
      ? {
          title: latestPost.data.title,
          slug: latestPost.id.split('/')[1],
          date: latestPost.data.date,
        }
      : null,
  };
});
---

<Layout title="Authors" description="All authors on this blog">
  <MainHeader slot="Main-Header"/>

  <section class="authors-page">

    <div class="page-header">
      <div class="header-label">Contributors</div>
      <h1>The <em>Authors</em></h1>
      <p class="subtitle">
        {authors.length} writer{authors.length !== 1 ? 's' : ''} sharing their thoughts
      </p>
    </div>

    <div class="authors-grid">
      {authors.map((author) => (
        <a
          href={`/${author.username}`}
          class="author-card"
        >
          <div class="card-inner">

            <div class="author-top">
              <div class="avatar-wrap">
                <img
                  src={author.avatar}
                  alt={author.name}
                  class="avatar"
                  width="64"
                  height="64"
                />
              </div>
              <div class="author-meta">
                <h2>{author.name}</h2>
                <p class="username">@{author.username}</p>
              </div>
              <span class="post-badge">
                {author.postCount}
              </span>
            </div>

            {author.bio && (
              <p class="bio">{author.bio}</p>
            )}

            {author.latestPost && (
              <div class="latest-post">
                <span class="latest-label">Latest</span>
                <span class="latest-title">{author.latestPost.title}</span>
              </div>
            )}

          </div>
        </a>
      ))}
    </div>

    {authors.length === 0 && (
      <div class="empty">
        <p>No authors yet.</p>
      </div>
    )}

  </section>

</Layout>

<style>
  /* ── Page ── */
  .authors-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  /* ── Header ── */
  .page-header {
    margin-bottom: 3rem;
  }

  .header-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.6rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 0.6rem 0;
    color: var(--color-text-main);
    letter-spacing: -0.02em;
  }

  .page-header h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  /* ── Grid ── */
  .authors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.25rem;
  }

  /* ── Card ── */
  .author-card {
    display: block;
    text-decoration: none;
    border-radius: 16px;
    padding: 2px;                          /* space for gradient border */
    background: var(--color-border);
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .author-card:hover {
    background: linear-gradient(
      135deg,
      var(--color-accent),
      transparent 60%
    );
    transform: translateY(-3px);
    box-shadow: 0 12px 32px -8px color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .card-inner {
    background: var(--color-bg-offset);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  /* ── Author top row ── */
  .author-top {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .avatar-wrap {
    flex-shrink: 0;
    border-radius: 50%;
    padding: 2px;
    background: var(--color-border);
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .author-card:hover .avatar-wrap {
    background: var(--color-accent);
    transform: translateY(-2px);
  }

  .avatar {
    display: block;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-meta {
    flex: 1;
    min-width: 0;
  }

  .author-meta h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.2rem 0;
    color: var(--color-text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .username {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Post count badge ── */
  .post-badge {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    transition: background 0.2s ease;
  }

  .author-card:hover .post-badge {
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  /* ── Bio ── */
  .bio {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Latest post ── */
  .latest-post {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.78rem;
  }

  .latest-label {
    flex-shrink: 0;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.65rem;
    color: var(--color-accent);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .latest-title {
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Empty state ── */
  .empty {
    text-align: center;
    padding: 5rem 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }


</style>