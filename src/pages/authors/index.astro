---
// src/pages/authors/index.astro
// Lists all authors derived from post folders
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MainHeader from '../../components/MainHeader.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allAuthors = await getCollection('authors');

// Get unique usernames from folder names
const usernames = [...new Set(allPosts.map((e) => e.id.split('/')[0]))];

// Build author cards
const authors = usernames.map((username) => {
  const profile = allAuthors.find((a) => a.id === username);
  const postCount = allPosts.filter((e) => e.id.split('/')[0] === username).length;
  const latestPost = allPosts
    .filter((e) => e.id.split('/')[0] === username)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

  return {
    username,
    name: profile?.data.name ?? username,
    avatar: profile?.data.avatar_url ?? `https://avatars.githubusercontent.com/${username}`,
    bio: profile?.data.bio ?? null,
    postCount,
    latestPost: latestPost
      ? {
          title: latestPost.data.title,
          slug: latestPost.id.split('/')[1],
          date: latestPost.data.date,
        }
      : null,
  };
});
---

<Layout title="Authors" description="All authors on this blog">
  <MainHeader slot="Main-Header"/>

  <section class="authors-page">

    <div class="page-header">
      <h1>Authors</h1>
      <p class="subtitle">{authors.length} author{authors.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="authors-grid">
      {authors.map((author) => (
        <a href={`/${author.username}`} class="author-card">

          <div class="author-top">
            <img
              src={author.avatar}
              alt={author.name}
              class="avatar"
              width="56"
              height="56"
            />
            <div>
              <h2>{author.name}</h2>
              <p class="username">@{author.username}</p>
            </div>
          </div>

          {author.bio && (
            <p class="bio">{author.bio}</p>
          )}

          <div class="author-footer">
            <span class="post-count">
              {author.postCount} post{author.postCount !== 1 ? 's' : ''}
            </span>

            {author.latestPost && (
              <span class="latest">
                Latest: {author.latestPost.title}
              </span>
            )}
          </div>

        </a>
      ))}
    </div>

    {authors.length === 0 && (
      <p class="empty">No authors yet.</p>
    )}

  </section>

</Layout>

<style>
  .authors-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2.2rem;
    margin-bottom: 0.4rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .authors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .author-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: var(--color-bg-offset);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .author-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .author-top {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border);
  }

  .author-top h2 {
    font-size: 1.05rem;
    margin: 0 0 0.2rem 0;
    color: var(--color-text-main);
  }

  .username {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .bio {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;

    /* clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .author-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .post-count {
    font-weight: 600;
    color: var(--color-accent);
  }

  .latest {
    max-width: 55%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .empty {
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 3rem;
  }
</style>
