---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Create Post">
  <div class="create-wrap">
    <div class="create-card">

      <div class="create-header">
        <h1>New Post</h1>
        <p>Write in Markdown. Publish instantly.</p>
      </div>

      <form id="post-form" novalidate>

        <div class="field-group">
          <label for="title">Title <span class="required">*</span></label>
          <input
            id="title"
            name="title"
            type="text"
            placeholder="My awesome post"
            required
          />
          <span class="field-error" id="title-error"></span>
        </div>

        <div class="field-group">
          <label for="slug">
            Slug
            <span class="label-hint">— auto-generated if left blank</span>
          </label>
          <input
            id="slug"
            name="slug"
            type="text"
            placeholder="my-awesome-post"
          />
        </div>

        <div class="field-group">
          <label for="content">Content <span class="required">*</span></label>
          <textarea
            id="content"
            name="content"
            placeholder="Write your post in Markdown..."
            rows="14"
            required
          ></textarea>
          <span class="field-error" id="content-error"></span>
        </div>

        <div class="field-group">
          <label for="tags">Tags</label>
          <input
            id="tags"
            name="tags"
            type="text"
            placeholder="astro, webdev, typescript"
          />
          <span class="field-hint">Separate with commas</span>
        </div>

        <div class="form-error" id="form-error" role="alert" aria-live="polite"></div>

        <div class="form-actions">
          <button type="submit" class="btn submit-btn" id="submit-btn">
            <span class="btn-label">Publish Post</span>
            <span class="btn-spinner" aria-hidden="true"></span>
          </button>
        </div>

      </form>
    </div>
  </div>
</Layout>

<style>
  .create-wrap {
    min-height: 70vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 3rem 1rem;
  }

  .create-card {
    width: 100%;
    max-width: 680px;
    background: var(--color-bg-offset);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2.5rem 2.25rem;
    box-shadow: var(--shadow-lg);
    animation: fadeUp 0.35s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .create-header {
    margin-bottom: 2rem;
  }

  .create-header h1 {
    font-size: 2rem;
    margin-bottom: 0.3rem;
  }

  .create-header p {
    margin: 0;
    font-size: 0.95rem;
  }

  /* Fields */
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.35rem;
  }

  label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-main);
    letter-spacing: 0.01em;
  }

  .required {
    color: #c0392b;
    margin-left: 2px;
  }

  .label-hint {
    font-weight: 400;
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.65rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-text-main);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    resize: vertical;
  }

  textarea {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    min-height: 280px;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  input:focus,
  textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-light);
  }

  input.invalid,
  textarea.invalid {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.12);
  }

  /* Hints & Errors */
  .field-hint {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .field-error {
    font-size: 0.78rem;
    color: #c0392b;
    min-height: 1em;
  }

  .form-error {
    display: none;
    background: rgba(192, 57, 43, 0.08);
    border: 1px solid rgba(192, 57, 43, 0.25);
    color: #c0392b;
    font-size: 0.875rem;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-sm);
    margin-bottom: 1.25rem;
  }

  .form-error.visible {
    display: block;
  }

  /* Actions */
  .form-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .submit-btn {
    min-width: 140px;
    justify-content: center;
    padding: 0.7rem 1.4rem;
    font-size: 1rem;
    position: relative;
  }

  .submit-btn.loading .btn-label {
    opacity: 0;
  }

  .submit-btn.loading .btn-spinner {
    display: block;
  }

  .btn-spinner {
    display: none;
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid rgba(255, 255, 255, 0.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 480px) {
    .create-card {
      padding: 1.75rem 1.25rem;
    }

    .form-actions {
      justify-content: stretch;
    }

    .submit-btn {
      width: 100%;
    }
  }
</style>

<script>
  const form = document.getElementById("post-form") as HTMLFormElement;
  const titleInput = document.getElementById("title") as HTMLInputElement;
  const slugInput = document.getElementById("slug") as HTMLInputElement;
  const contentInput = document.getElementById("content") as HTMLTextAreaElement;
  const titleError = document.getElementById("title-error")!;
  const contentError = document.getElementById("content-error")!;
  const formError = document.getElementById("form-error")!;
  const submitBtn = document.getElementById("submit-btn")!;

  // Auto-generate slug from title
  titleInput.addEventListener("input", () => {
    titleInput.classList.remove("invalid");
    titleError.textContent = "";

    if (!slugInput.value || slugInput.dataset.userEdited !== "true") {
      slugInput.value = titleInput.value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-");
    }
  });

  // Mark slug as manually edited
  slugInput.addEventListener("input", () => {
    slugInput.dataset.userEdited = "true";
  });

  contentInput.addEventListener("input", () => {
    contentInput.classList.remove("invalid");
    contentError.textContent = "";
  });

  function setLoading(loading: boolean) {
    submitBtn.classList.toggle("loading", loading);
    (submitBtn as HTMLButtonElement).disabled = loading;
  }

  function showFormError(msg: string) {
    formError.textContent = msg;
    formError.classList.add("visible");
  }

  function clearFormError() {
    formError.textContent = "";
    formError.classList.remove("visible");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearFormError();

    // Validation
    let valid = true;

    if (!titleInput.value.trim()) {
      titleInput.classList.add("invalid");
      titleError.textContent = "Title is required.";
      valid = false;
    }

    if (!contentInput.value.trim()) {
      contentInput.classList.add("invalid");
      contentError.textContent = "Content is required.";
      valid = false;
    }

    if (!valid) return;

    setLoading(true);

    try {
      const res = await fetch("/api/posts/create", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title: titleInput.value.trim(),
          slug: slugInput.value.trim() || undefined,
          content: contentInput.value.trim(),
          tags: (document.getElementById("tags") as HTMLInputElement).value
            .split(",")
            .map((t) => t.trim())
            .filter(Boolean),
        }),
      });

      const data = await res.json();

      if (res.ok) {
        window.location.href = `/users/${data.username}/blog/${data.slug}`;
      } else {
        showFormError(data.error || "Failed to create post. Please try again.");
      }
    } catch {
      showFormError("Something went wrong. Please check your connection.");
    } finally {
      setLoading(false);
    }
  });
</script>