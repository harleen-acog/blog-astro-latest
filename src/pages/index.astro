---
import Layout from "../layouts/Layout.astro";
import { url } from "../utils/paths";
import "../styles/global.css";
import { getCollection } from "astro:content";
import MainHeader from "../components/MainHeader.astro";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const latestPosts = allPosts
  .map((entry) => {
    const [username, slug] = entry.id.split("/");
    return {
      username,
      slug,
      title: entry.data.title,
      description: entry.data.description,
      date: entry.data.date,
      tags: entry.data.tags,
      cover: entry.data.cover,
      coverAlt: entry.data.coverAlt,
    };
  })
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 20);
---

<Layout title="Home">
  <MainHeader slot="Main-Header"/>

  <section class="hero" slot="Hero-Section">
    <div class="hero-overlay">
      <h1>Where AI meets Science</h1>
      <p>Exploring the intersection of artificial intelligence and scientific discovery.</p>
      <a href="/posts" class="btn">Explore All Posts →</a>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Latest Posts</h2>
      <a href="/authors" class="view-all">See All →</a>
    </div>

    {
      latestPosts.length === 0 ? (
        <p>No posts yet.</p>
      ) : (
        <div class="post-grid">
          {latestPosts.map((post) => (
            <article class="post-card">
              <a href={url(`${post.username}/blog/${post.slug}`)} class="cover-link">
                {post.cover ? (
                  typeof post.cover === "string" ? (
                    <img src={post.cover} alt={post.coverAlt || post.title} class="cover-img" />
                  ) : (
                    <img
                      src={post.cover.src}
                      width={post.cover.width}
                      height={post.cover.height}
                      alt={post.coverAlt || post.title}
                      class="cover-img"
                    />
                  )
                ) : (
                  <div class="cover-fallback">
                    <span>{post.title}</span>
                  </div>
                )}
              </a>

              <div class="post-content">
                <a href={url(`${post.username}/blog/${post.slug}`)} class="post-title">
                  {post.title}
                </a>

                <div class="post-meta">
                  <span class="meta-author">{post.username}</span>
                  <span class="meta-sep">·</span>
                  <span>{post.date.toLocaleDateString()}</span>
                </div>

                {post.description && <p class="post-desc">{post.description}</p>}

                {post.tags?.length > 0 && (
                  <div class="tags">
                    {post.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      )
    }
  </section>
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    height: 27rem;
    text-align: center;
    background-image: url("https://plus.unsplash.com/premium_photo-1733317429945-a3688f50430b?q=80&w=1315&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D");
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero-overlay {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 2rem;
    background: linear-gradient(160deg, rgba(1, 24, 47, 0.78) 0%, rgba(0, 0, 0, 0.55) 100%);
  }

  .hero h1 {
    font-size: 2.8rem;
    margin-bottom: 0.25rem;
    color: #ffffff;
  }

  .hero p {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.5rem;
  }

  /* SECTION */
  .section {
    max-width: 1000px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-accent);
  }

  .section-header h2 {
    border-bottom: none;
    margin: 0;
    padding: 0;
  }

  .view-all {
    font-size: 0.88rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .view-all:hover {
    text-decoration: underline;
  }

  /* GRID */
  .post-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  /* CARD */
  .post-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-offset);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  /* COVER */
  .cover-link {
    display: block;
  }

  .cover-img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    display: block;
  }

  .cover-fallback {
    height: 170px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: linear-gradient(135deg, var(--color-accent), #6b7280);
    color: white;
    font-family: var(--font-serif);
    font-weight: 600;
    text-align: center;
    font-size: 1rem;
  }

  /* CONTENT */
  .post-content {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-main);
    line-height: 1.35;
    text-decoration: none;
    display: block;
    transition: color var(--transition-fast);
  }

  .post-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .meta-author {
    color: var(--color-accent);
  }

  .meta-sep {
    color: var(--color-border);
  }

  .post-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.4rem;
  }
</style>