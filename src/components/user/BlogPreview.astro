---
const { posts, username } = Astro.props;
---

<section class="blog-preview">
  <div class="section-header">
    <h2>Latest Posts</h2>
    <a href={`${username}/blog`} class="view-all">
      View all
    </a>
  </div>

  <div class="post-list">
    {posts.map((post) => (
      <article class="post-card">
        <a href={`${username}/blog/${post.slug}`} class="post-link">
          <h3>{post.title}</h3>
        </a>

        {post.date && (
          <p class="post-meta">
            {new Date(post.date).toLocaleDateString()}
          </p>
        )}

        {post.description && (
          <p class="post-excerpt">{post.description}</p>
        )}
      </article>
    ))}
  </div>
</section>

<style>
.blog-preview {
  margin: 2.5rem 0;
}

/* Header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.section-header h2 {
  margin: 0;
  font-size: 1.4rem;
}

.view-all {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-accent);
  text-decoration: none;
}

.view-all:hover {
  text-decoration: underline;
}

/* List */
.post-list {
  display: grid;
  gap: 1.25rem;
}

/* Card */
.post-card {
  padding: 1.2rem 1.3rem;
  border: 1px solid var(--color-border);
  border-radius: 12px;
  background: var(--color-bg-offset);
  transition: all 0.2s ease;
}

.post-card:hover {
  transform: translateY(-2px);
  border-color: var(--color-accent);
  box-shadow: var(--shadow-sm);
}

/* Title */
.post-link {
  text-decoration: none;
}

.post-link h3 {
  margin: 0 0 0.4rem 0;
  font-size: 1.05rem;
  color: var(--color-text-main);
}

.post-link:hover h3 {
  color: var(--color-accent);
}

/* Meta */
.post-meta {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  margin-bottom: 0.5rem;
}

/* Excerpt */
.post-excerpt {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.5;
}
</style>