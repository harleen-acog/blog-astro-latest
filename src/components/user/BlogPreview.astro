---
const { posts, username } = Astro.props;

// show max 4 posts in preview
const previewPosts = posts.slice(0, 4);
---

<section class="blog-preview">

  <div class="section-header">
    <div class="header-left">
      <p class="eyebrow">Writing</p>
      <h2>Latest Posts</h2>
    </div>
    <a href={`/${username}/blog`} class="view-all">
      View all
    </a>
  </div>

  <div class="post-list">
    {previewPosts.map((post) => (
      <a href={`/${username}/blog/${post.slug}`} class="post-card">

        <div class="post-body">
          <div class="post-meta-row">
            {post.date && (
              <time class="post-date">
                {new Date(post.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            )}
            {post.tags && post.tags.length > 0 && (
              <div class="tags">
                {post.tags.slice(0, 2).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>

          <h3>{post.title}</h3>

          {post.description && (
            <p class="post-excerpt">{post.description}</p>
          )}
        </div>

       

      </a>
    ))}
  </div>

  {posts.length === 0 && (
    <p class="empty">No posts yet.</p>
  )}

</section>

<style>
  .blog-preview {
    margin: 2.5rem 0;
  }

  /* ── Header ── */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.3rem 0;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text-main);
  }

  .view-all {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding-bottom: 0.2rem;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .view-all:hover {
    border-bottom-color: var(--color-accent);
  }

  .view-all .arrow {
    transition: transform 0.2s ease;
  }

  .view-all:hover .arrow {
    transform: translateX(3px);
  }

  /* ── List ── */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Card ── */
  .post-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: padding-left 0.2s ease,
                border-left-color 0.2s ease,
                background 0.2s ease;
  }

  .post-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-card:hover {
    padding-left: 1rem;
    border-left-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
  }

  /* ── Post body ── */
  .post-body {
    flex: 1;
    min-width: 0;
  }

  /* ── Meta row ── */
  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .tags {
    display: flex;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.12rem 0.45rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
  }

  /* ── Title ── */
  .post-card h3 {
    margin: 0 0 0.3rem 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-card:hover h3 {
    color: var(--color-accent);
  }

  /* ── Excerpt ── */
  .post-excerpt {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Arrow ── */
  .card-arrow {
    flex-shrink: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .post-card:hover .card-arrow {
    transform: translateX(3px);
    color: var(--color-accent);
  }

  /* ── Empty ── */
  .empty {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    padding: 2rem 0;
    text-align: center;
  }
</style>