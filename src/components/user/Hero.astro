---
import { Image } from "astro:assets";

const { user } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <h1 style="margin-bottom: 0.5rem; font-size: 3rem;">
      {user.name}
    </h1>

    <h2 style="font-weight: 400; color: var(--color-text-muted); margin-bottom: 1.5rem; text-transform: uppercase; font-size: 1rem;">
      {user.role}
    </h2>

    <p style="font-size: 1.1rem; line-height: 1.7; margin-bottom: 2rem;">
      {user.about}
    </p>

    <div class="hero-buttons">
      <a href={`/users/${user.username}/blog`} class="btn">
        View Blog
      </a>
      <!-- <a href={`/users/${user.username}/projects`} class="btn btn-outline">
        Projects
      </a> -->
    </div>
  </div>

  <div class="hero-image">
    <Image
      src={`https://i.pravatar.cc/300?u=${user.id}`}
      width={280}
      height={280}
      alt="Profile"
    />
  </div>
</section>

<style>
.hero {
  display: flex;
  align-items: center;
  gap: 4rem;
  padding: 4rem 0;
}
.hero-content { flex: 3; }
.hero-image { flex: 2; text-align: center; }

.hero-image img {
  width: 280px;
  height: 280px;
  object-fit: cover;
  border-radius: 50%;
}
</style>