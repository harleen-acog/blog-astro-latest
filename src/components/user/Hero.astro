---
import { Image } from "astro:assets";

const { user } = Astro.props;
---

<section class="hero">

  <div class="hero-content">
    <p class="hero-eyebrow">@{user.username}</p>

    <h1>{user.name}</h1>

    {user.bio && (
      <p class="hero-bio">{user.bio}</p>
    )}

    <div class="hero-actions">
      <a href={`/${user.username}/blog`} class="btn-primary">
        Read Posts
      </a>
    </div>
  </div>

  <div class="hero-image">
    <div class="avatar-ring">
      <Image
        src={user.avatar}
        alt={user.name}
        width={280}
        height={280}
        class="avatar"
      />
    </div>
  </div>

</section>

<style>
  /* ── Layout ── */
  .hero {
    display: flex;
    align-items: center;
    gap: 4rem;
    padding: 4rem 0 3rem;
  }

  .hero-content {
    flex: 3;
    min-width: 0;
  }

  .hero-image {
    flex: 2;
    display: flex;
    justify-content: center;
  }

  /* ── Eyebrow ── */
  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem 0;
  }

  /* ── Name ── */
  .hero-content h1 {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 1.1rem 0;
    color: var(--color-text-main);
  }

  /* ── Bio ── */
  .hero-bio {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 2rem 0;
    max-width: 48ch;
  }

  /* ── Actions ── */
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.4rem;
    border-radius: 10px;
    background: var(--color-accent);
    color: white;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .btn-arrow {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(3px);
  }

  /* ── Avatar ── */
  .avatar-ring {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(
      135deg,
      var(--color-accent),
      color-mix(in srgb, var(--color-accent) 30%, transparent)
    );
    transition: transform 0.3s ease;
  }

  .avatar-ring:hover {
    transform: scale(1.02);
  }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    background: var(--color-bg-offset);  /* fallback while loading */
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero {
      flex-direction: column-reverse;
      gap: 2rem;
      padding: 2.5rem 0;
      text-align: center;
    }

    .hero-bio {
      max-width: 100%;
    }

    .hero-actions {
      justify-content: center;
    }

    .avatar-ring {
      width: 180px;
      height: 180px;
    }
  }
</style>