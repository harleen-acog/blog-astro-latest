---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro"; // if you have one
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title = "Site",
  description = "Default description",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
	<slot name="Header"/>
	<slot name="Hero-Section"/>
    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
html, body {
  margin: 0;
  min-height: 100%;
}

main {
  min-height: 70vh;
}
</style>