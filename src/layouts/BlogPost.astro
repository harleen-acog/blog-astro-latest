---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
const { post, username, slug } = Astro.props;

const user = { name: username, username };
---

<html lang="en">
  <head>
    <BaseHead title={post.title} description={post.description} />
  </head>

  <body>
    <Header user={user} />

    <main class="container">
      <article
        class="blog-post"
        data-pagefind-body
        data-pagefind-meta={`title:${post.title}`}
      >
        <div class="title">
          <div class="date">
            {post.date.toLocaleDateString()}
          </div>
          <h1>{post.title}</h1>
          <p class="author-line">
            by{" "}
            {
              post.contributors.map((c, i) => (
                <>
                  <a href={`/${c}`}>{c}</a>
                  {i < post.contributors.length - 1 && " | "}
                </>
              ))
            }
          </p>
          {
            post.tags.length > 0 && (
              <div class="tags">
                {post.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )
          }
        </div>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .title {
    text-align: center;
    margin-bottom: 2rem;
  }

  .title h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .date {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .prose {
    line-height: 1.7;
    color: var(--color-text-main);
  }

  .prose p {
    margin-bottom: 1rem;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2rem;
  }

  .prose img {
    max-width: 100%;
    border-radius: 10px;
  }

  .prose code {
    background: var(--color-bg-offset);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prose pre {
    background: var(--color-bg-offset);
    padding: 1.25rem;
    border-radius: 10px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose pre code {
    background: none;
    padding: 0.5rem;
  }

  .prose a {
    color: var(--color-accent);
  }

  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    margin-left: 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
